# =========================================
# Example environment file for Moodboard AI
# Copy this file to .env and fill in your
# own values. DO NOT commit .env!
# =========================================

# ---------- Backend (ASP.NET Core) ----------

# Access key for the OpenAI / Groq API
OPENAI_API_KEY=your_openai_or_groq_api_key_here

# Base URL of the API (optional, only needed for non-OpenAI providers)
# OpenAI:  https://api.openai.com/v1
# Groq:    https://api.groq.com/openai/v1
OPENAI_API_BASE_URL=https://api.openai.com/v1

# Access key for the Unsplash API
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# PostgreSQL connection string
CONNECTIONSTRINGS__DEFAULTCONNECTION=Host=aws-0-eu-west-1.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.fbetndsaukfezfmhjelv;Password=<your-password>;SSL Mode=Require;Trust Server Certificate=true

# Runtime environment (Development / Staging / Production)
ASPNETCORE_ENVIRONMENT=Development

# Secret key used to sign JWT tokens (generate with: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_here


# ---------- Frontend (React) ----------

# Base URL of the backend API
VITE_API_BASE_URL=http://localhost:5000/api
